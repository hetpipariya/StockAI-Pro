# ─── Database ───
# Railway automatically sets DATABASE_URL when you provision a PostgreSQL plugin.
# If DATABASE_URL is not set, or if it uses the docker-compose hostname 'postgres',
# the app will fall back to a local SQLite database (stockai.db).
#
# Railway (PostgreSQL plugin auto-sets this — no manual change needed):
#   DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.railway.app:5432/<db>
#
# Local docker-compose (handled automatically — falls back to SQLite on Railway):
#   DATABASE_URL=postgresql+asyncpg://postgres:stockaipassword@postgres:5432/stockai
#
# Local SQLite fallback (default when DATABASE_URL is not set):
DATABASE_URL=sqlite+aiosqlite:///./stockai.db

# ─── Redis (optional — falls back to in-memory if unavailable) ───
REDIS_URL=redis://localhost:6379/0

# ─── Market Hours (IST) ───
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
