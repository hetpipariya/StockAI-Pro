# ─── Database ───
# LOCAL DEVELOPMENT: SQLite (default — no extra setup needed)
DATABASE_URL=sqlite+aiosqlite:///./stockai.db

# RAILWAY DEPLOYMENT:
#   Railway auto-injects DATABASE_URL when you add a PostgreSQL plugin.
#   Leave this line commented out; Railway will set it for you.
#   If you need to set it manually, use the full connection string, e.g.:
#   DATABASE_URL=postgresql+asyncpg://user:pass@hostname.railway.app:5432/dbname
#
# NOTE: Do NOT use the docker-compose hostname 'postgres' on Railway — it will
# fail with "could not translate host name 'postgres'".  The app detects this
# and falls back to SQLite automatically.

# ─── Redis (optional — falls back to in-memory if unavailable) ───
REDIS_URL=redis://localhost:6379/0

# ─── Market Hours (IST) ───
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
