# ─── ANGELONE SMARTAPI CREDENTIALS ───
# Required for real market data and trading.
ANGEL_API_KEY="your_angel_api_key_here"
ANGEL_CLIENT_ID="your_angel_client_id_here"
ANGEL_PASSWORD="your_angel_password_here"
ANGEL_TOTP_SECRET="your_angel_totp_secret_here"

# ─── SECURITY SETTINGS ───
# CRITICAL: Change this to a secure random string in production! e.g. `openssl rand -hex 32`
# If left blank or default, the backend will refuse to start for security reasons.
JWT_SECRET="your_super_secret_jwt_key_here"

# ─── CORS SETTINGS ───
# Comma-separated list of allowed origins.
# In production, set this to your exact frontend domain (e.g. https://trading.yourdomain.com)
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# ─── TRADING ENGINE CONFIGURATION ───
# "PAPER" for simulated trading, "LIVE" for real-money execution.
TRADING_MODE="PAPER"
# If MODE="LIVE", this MUST be "true" to enable actual order placement. Acts as a safety gate.
LIVE_CONFIRMED="false"
# Master kill-switch. "true" enables signals/orders, "false" pauses the engine.
TRADING_ENABLED="true"

# Risk and Sizing
MAX_RISK_PER_TRADE_PCT="1.0"
MAX_DAILY_LOSS_PCT="3.0"
MAX_CONCURRENT_POSITIONS="3"
MAX_TRADES_PER_DAY="10"

# ─── DATA & FALLBACK SETTINGS ───
# Enable returning fake random data if SmartAPI fails.
# CRITICAL: MUST be "false" in a production environment to prevent trading on fake pricing.
ENABLE_MOCK_DATA="false"

# ─── DATABASE & REDIS ───
# Railway: DATABASE_URL is set automatically by the PostgreSQL plugin.
# The app detects whether DATABASE_URL is valid for the environment:
#   - If empty or using the local docker-compose hostname 'postgres', it falls
#     back to SQLite (stockai.db) automatically.
#   - For Railway deployment, leave DATABASE_URL unset here and let Railway
#     inject it via the PostgreSQL plugin environment variable.
#
# Docker-compose local (uses service hostname 'postgres' — auto-fallback on Railway):
DATABASE_URL="postgresql+asyncpg://postgres:stockaipassword@postgres:5432/stockai"
REDIS_URL="redis://redis:6379/0"
